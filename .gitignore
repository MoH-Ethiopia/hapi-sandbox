# macOS
.DS_Store

# H2 runtime database (bind-mounted via docker-compose; safe to delete to reset)
data/

# Local per-deployment config (committed as .env.example instead)
.env

# IG package build artifacts mounted into HAPI (the dir is kept via igs/.gitkeep).
# Rebuild with harness/scripts/refresh-core-ig.sh, or use the published packageUrl.
igs/*.tgz

# Karate harness build artifacts
harness/karate-*.jar
harness/target/
