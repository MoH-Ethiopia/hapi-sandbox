# HTTP-only entrypoint. TLS is the fronting reverse proxy's job (or none, in dev).
:8080 {
	encode gzip

	# Validate via HAPI's standard operation under /fhir: POST /fhir/{Type}/$validate
	# (and /fhir/Bundle/$validate). Validate-and-report path is /intercept.

	handle_path /intercept* {
		reverse_proxy interceptor:8080
	}

	handle_path /docs* {
		root * /srv/docs
		file_server browse
	}

	handle_path /sim* {
		root * /srv/sim
		file_server browse
	}

	handle /fhir/* {
		reverse_proxy fhir-server:8080 {
			health_uri /fhir/metadata
			health_interval 15s
			health_timeout 5s
		}
	}

	redir / /docs/ 302
}
