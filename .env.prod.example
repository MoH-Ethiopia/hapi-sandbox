# Production .env for running behind the host reverse proxy (nginx). Copy to .env.
#   docker compose up -d
# The host nginx terminates TLS and forwards to the gateway (see
# deploy/nginx/sandbox.fhir.et.conf). Gateway binds 127.0.0.1 only — never 80/443.

DOMAIN=sandbox.fhir.et
PUBLIC_BASE_URL=https://sandbox.fhir.et/fhir

GATEWAY_PORT=8095        # nginx upstream — must be a free port (not 80/443)
HAPI_DEBUG_PORT=8090     # 127.0.0.1 direct HAPI access (debugging)

# IG packages default to published GitHub Pages builds — no build needed on the server.
