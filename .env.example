# Copy this file to .env and adjust for your environment.
#
# Local:    DOMAIN=localhost            -> Caddy uses its internal self-signed CA
# Deployed: DOMAIN=fhir-et.example.org  -> Caddy auto-provisions a Let's Encrypt cert
#
# The same docker-compose.yml + Caddyfile work in both modes; only this file changes.
DOMAIN=localhost

# Email registered with Let's Encrypt (expiry notices / account recovery).
# Used only when DOMAIN is a public name; ignored for localhost.
ACME_EMAIL=admin@example.org

# Loopback-only direct-HAPI debug port (bound to 127.0.0.1, not internet-exposed).
HAPI_DEBUG_PORT=8090

# ET core IG source. Defaults (below) load the LOCAL dev build at
# ./igs/et.fhir.core.tgz (run harness/scripts/refresh-core-ig.sh first).
# Once the IG is published, switch to the hosted package — no code change:
#   ET_IG_PACKAGE_URL=https://fhir.et/core/package.tgz
#   ET_IG_VERSION=0.9.0
# ET_IG_PACKAGE_URL=file:///igs/et.fhir.core.tgz
# ET_IG_VERSION=dev
