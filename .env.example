# Copy to .env and adjust. The gateway is the single HTTP entrypoint on
# 127.0.0.1:${GATEWAY_PORT}; front it with a TLS-terminating reverse proxy in
# production, or open http://localhost:${GATEWAY_PORT}/docs/ in dev.

DOMAIN=localhost
PUBLIC_BASE_URL=http://localhost:8095/fhir   # HAPI's advertised base URL

GATEWAY_PORT=8095        # host port for the gateway (proxy forwards here)
HAPI_DEBUG_PORT=8090     # 127.0.0.1 direct HAPI access (debugging)

# ET IGs default to their published GitHub Pages builds — nothing to set. For an
# offline build, point at local tgz (build with harness/scripts/refresh-core-ig.sh):
#   ET_IG_PACKAGE_URL=file:///igs/et.fhir.core.tgz
#   ET_SURVEILLANCE_PKG_URL=file:///igs/et.fhir.surveillance.tgz
#   ET_HIV_PKG_URL=file:///igs/et.fhir.hiv.tgz
